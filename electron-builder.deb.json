{
  "appId": "com.lingjing.ide",
  "productName": "灵境",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "renderer/**/*",
    "node_modules/**/*",
    "package.json"
  ],
  "linux": {
    "target": [
      {
        "target": "deb",
        "arch": ["x64"]
      }
    ],
    "icon": "assets",
    "category": "Development",
    "executableName": "lingjing",
    "artifactName": "LingJing-${version}-linux-x86_64.${ext}"
  },
  "deb": {
    "compression": "gzip"
  },
  "publish": {
    "provider": "generic",
    "url": "https://ide.zhejiangjinmo.com/downloads/"
  }
}
