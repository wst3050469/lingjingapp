# Aliyun OSS Configuration
OSS_ACCESS_KEY_ID=your_access_key_id_here
OSS_ACCESS_KEY_SECRET=your_access_key_secret_here
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=your_bucket_name_here

# Deployment Paths
# Local directory containing build artifacts to upload
LOCAL_ARTIFACTS_DIR=packages/electron/release-v1601-win
# Remote path in OSS (e.g., 'downloads/v1.60.1')
OSS_REMOTE_PREFIX=downloads/v1.60.1
