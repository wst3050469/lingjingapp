# 通用配置
NODE_ENV=production

# cloud-server 配置
PORT=8000
# API密钥（至少32字符，生产环境必须替换）
API_KEY=your-api-key-at-least-32-chars-placeholder
# JWT密钥（至少32字符，生产环境必须替换）
JWT_SECRET=your-jwt-secret-at-least-32-chars-placeholder
# DeepSeek API配置
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# cloud-admin / Nginx 配置
NGINX_PORT=80

# Docker镜像配置
IMAGE_TAG=latest