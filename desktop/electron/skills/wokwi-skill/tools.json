{
  "wokwi_simulate": { "name": "wokwi_simulate", "description": "运行电路仿真", "parameters": { "type": "object", "properties": { "circuitJson": { "type": "object" }, "duration": { "type": "number", "default": 1000 } }, "required": ["circuitJson"] }, "returns": { "type": "object", "properties": { "success": { "type": "boolean" }, "results": { "type": "object" } } }, "timeout": 30000 },
  "wokwi_arduino_simulate": { "name": "wokwi_arduino_simulate", "description": "Arduino/ESP32项目仿真", "parameters": { "type": "object", "properties": { "sketchPath": { "type": "string" }, "board": { "type": "string", "enum": ["arduino-uno", "arduino-mega", "esp32"], "default": "arduino-uno" } }, "required": ["sketchPath"] }, "returns": { "type": "object", "properties": { "success": { "type": "boolean" }, "serialOutput": { "type": "string" } } }, "timeout": 60000 },
  "wokwi_waveform_subscribe": { "name": "wokwi_waveform_subscribe", "description": "订阅实时波形数据", "parameters": { "type": "object", "properties": { "signals": { "type": "array", "items": { "type": "string" } }, "duration": { "type": "number" } }, "required": ["signals"] }, "returns": { "type": "object", "properties": { "success": { "type": "boolean" }, "subscriptionId": { "type": "string" } } }, "timeout": 5000 },
  "wokwi_schematic_convert": { "name": "wokwi_schematic_convert", "description": "KiCad原理图与Wokwi互转", "parameters": { "type": "object", "properties": { "sourcePath": { "type": "string" }, "direction": { "type": "string", "enum": ["kicad-to-wokwi", "wokwi-to-kicad"] } }, "required": ["sourcePath", "direction"] }, "returns": { "type": "object", "properties": { "success": { "type": "boolean" }, "outputPath": { "type": "string" } } }, "timeout": 30000 }
}