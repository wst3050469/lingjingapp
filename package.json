{
  "name": "lingjing-ai",
  "version": "1.72.28",
  "description": "灵境AI - AI 驱动的智能开发平台",
  "homepage": "https://ide.zhejiangjinmo.com",
  "author": "LingJing AI <support@lingjing.ai>",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export --platform web",
    "setup": "pnpm install --frozen-lockfile",
    "build:core": "pnpm --filter @codepilot/core build",
    "build:renderer": "pnpm --filter @codepilot/renderer build",
    "build:electron": "pnpm --filter lingjing-ide build",
    "dist:mac": "pnpm --filter lingjing-ide dist:mac",
    "dist:linux": "pnpm --filter lingjing-ide dist:linux",
    "dist:win": "pnpm --filter lingjing-ide dist"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "babel-preset-expo": "~55.0.22",
    "expo": "~55.0.26",
    "expo-asset": "~55.0.17",
    "expo-clipboard": "~55.0.13",
    "expo-crypto": "~55.0.15",
    "expo-font": "~55.0.8",
    "expo-notifications": "~55.0.23",
    "expo-status-bar": "~55.0.6",
    "expo-system-ui": "~55.0.18",
    "react": "19.2.6",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "~4.25.2",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.7.4",
    "ssh2": "^1.17.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "~19.2.17",
    "@types/uuid": "^10.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "~5.9.3",
    "undefined": "^0.1.0"
  },
  "private": true
}
